# === WB Chat Bot Configuration ===

# Wildberries Buyers Chat API token (права: Чат с покупателями)
WB_API_TOKEN=

# Wildberries Content API token (права: Контент)
# Нужен для загрузки каталога товаров с названиями
# Если не указан, используется WB_API_TOKEN
WB_CONTENT_TOKEN=

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for notifications (your personal or group chat ID)
TELEGRAM_CHAT_ID=

# Mode: "dry-run" (no real sends) or "production" (sends messages)
APP_MODE=dry-run

# How often to poll WB for new events (seconds)
POLL_INTERVAL_SECONDS=3

# Delay before sending message to new chat (seconds)
NEW_CHAT_DELAY_SECONDS=5

# Message text to send to new chats
MESSAGE_TEXT=тест

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# SQLite database path
DB_PATH=./data/app.db

# Heartbeat log interval (minutes)
HEARTBEAT_INTERVAL_MINUTES=30

# === Filters (optional) ===

# On which ratings to auto-reply (comma-separated, 1-5)
# Empty = respond to all ratings
# Example: REPLY_TO_RATINGS=1,2,3 — only negative reviews
REPLY_TO_RATINGS=

# Product whitelist: only respond to chats about these products (nmID)
# Empty = respond to all products
# Example: PRODUCT_WHITELIST=12345678,87654321
PRODUCT_WHITELIST=

# Product blacklist: never respond to chats about these products (nmID)
# Empty = don't ignore any products
# Example: PRODUCT_BLACKLIST=99999999
PRODUCT_BLACKLIST=
